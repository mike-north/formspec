{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "customerName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "title": "Customer Name",
      "description": "Full legal name"
    },
    "customerEmail": {
      "type": "string",
      "title": "Customer Email"
    },
    "quantity": {
      "type": "number",
      "minimum": 1,
      "maximum": 999,
      "title": "Quantity"
    },
    "unitPrice": {
      "type": "number",
      "minimum": 0,
      "maximum": 99999,
      "title": "Unit Price"
    },
    "priority": {
      "enum": ["low", "normal", "high", "urgent"],
      "title": "Priority"
    },
    "shippingMethod": {
      "enum": ["standard", "express", "overnight"],
      "title": "Shipping Method"
    },
    "expressInstructions": {
      "type": "string",
      "title": "Express Instructions"
    },
    "discountCode": {
      "type": "string",
      "title": "Discount Code"
    }
  },
  "required": [
    "customerName",
    "customerEmail",
    "quantity",
    "unitPrice",
    "priority",
    "shippingMethod"
  ]
}
