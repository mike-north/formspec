{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "Customer",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/customerName",
          "label": "Customer Name"
        },
        {
          "type": "Control",
          "scope": "#/properties/customerEmail",
          "label": "Customer Email"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Order Details",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/quantity",
          "label": "Quantity"
        },
        {
          "type": "Control",
          "scope": "#/properties/unitPrice",
          "label": "Unit Price"
        },
        {
          "type": "Control",
          "scope": "#/properties/priority",
          "label": "Priority"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Shipping",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/shippingMethod",
          "label": "Shipping Method"
        },
        {
          "type": "Control",
          "scope": "#/properties/expressInstructions",
          "label": "Express Instructions",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/shippingMethod",
              "schema": {
                "const": "express"
              }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/discountCode",
          "label": "Discount Code"
        }
      ]
    }
  ]
}
