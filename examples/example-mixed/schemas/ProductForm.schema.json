{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "title": "Product Name"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "maximum": 99999,
      "title": "Price"
    },
    "weight": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 1000,
      "title": "Weight (kg)"
    },
    "sku": {
      "type": "string",
      "pattern": "^[A-Z]{3}-\\d{4}$",
      "title": "SKU"
    },
    "stock": {
      "type": "number",
      "minimum": 0,
      "exclusiveMaximum": 10000,
      "title": "Stock Count"
    },
    "batchCode": {
      "type": "string",
      "minLength": 5,
      "maxLength": 20,
      "title": "Batch Code"
    },
    "category": {
      "enum": ["electronics", "clothing", "food", "other"],
      "title": "Category"
    },
    "expiryDays": {
      "type": "number",
      "minimum": 1,
      "maximum": 365,
      "title": "Expiry Days"
    }
  },
  "required": ["name", "price", "weight", "sku", "stock", "category"]
}
