{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Task Name",
      "description": "A short name for this task"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "priority": {
      "type": "number",
      "minimum": 1,
      "title": "Priority"
    },
    "status": {
      "enum": ["todo", "in-progress", "done"],
      "title": "Status"
    },
    "assignee": {
      "type": "string",
      "title": "Assignee"
    },
    "submitLabel": {
      "type": "string",
      "title": "Submit Action"
    },
    "cancelLabel": {
      "type": "string",
      "title": "Cancel Action"
    }
  },
  "required": ["name", "priority", "status", "submitLabel"]
}
