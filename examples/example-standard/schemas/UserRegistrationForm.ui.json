{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "Personal Information",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/name",
          "label": "Full Name"
        },
        {
          "type": "Control",
          "scope": "#/properties/email",
          "label": "Email Address"
        },
        {
          "type": "Control",
          "scope": "#/properties/age",
          "label": "Age"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Account",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/username",
          "label": "Username"
        },
        {
          "type": "Control",
          "scope": "#/properties/accountType",
          "label": "Account Type"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Preferences",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/language",
          "label": "Preferred Language"
        },
        {
          "type": "Control",
          "scope": "#/properties/newsletter",
          "label": "Newsletter"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Business Details",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/companyName",
          "label": "Company Name",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/accountType",
              "schema": {
                "const": "business"
              }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/taxId",
          "label": "Tax ID",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/accountType",
              "schema": {
                "const": "business"
              }
            }
          }
        }
      ]
    },
    {
      "type": "Control",
      "scope": "#/properties/plan",
      "label": "Plan"
    },
    {
      "type": "Control",
      "scope": "#/properties/referralCode",
      "label": "Referral Code"
    }
  ]
}
