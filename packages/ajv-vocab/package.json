{
  "name": "@formspec/ajv-vocab",
  "version": "0.1.0-alpha.11",
  "description": "Ajv vocabulary registration for FormSpec annotation keywords",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/ajv-vocab.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ajv-vocab.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly && api-extractor run --local",
    "clean": "rm -rf dist temp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "api-extractor": "api-extractor run",
    "api-extractor:local": "api-extractor run --local",
    "api-documenter": "api-documenter markdown -i temp -o docs"
  },
  "peerDependencies": {
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "ajv": "^8.13.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "formspec",
    "ajv",
    "vocabulary",
    "jsonschema"
  ],
  "license": "UNLICENSED"
}
