{
  "name": "@formspec/ts-plugin",
  "version": "0.1.0-alpha.60",
  "description": "TypeScript language service plugin for FormSpec semantic comment analysis",
  "type": "module",
  "main": "./index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/ts-plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ts-plugin.d.ts",
      "import": "./dist/index.js",
      "require": "./index.cjs"
    }
  },
  "files": [
    "dist",
    "index.cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly -p tsconfig.build.json && pnpm run api-extractor:local",
    "clean": "rm -rf dist temp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "api-extractor": "api-extractor run && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-extractor:local": "api-extractor run --local && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-documenter": "api-documenter markdown -i temp -o docs && node ../../scripts/normalize-generated-markdown.mjs docs"
  },
  "dependencies": {
    "@formspec/analysis": "workspace:*",
    "@formspec/core": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
