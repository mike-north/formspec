{
  "name": "@formspec/language-server",
  "version": "0.1.0-alpha.69",
  "description": "Language server for FormSpec — completions and hover for JSDoc constraint tags",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/formspec.git",
    "directory": "packages/language-server"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/language-server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/language-server.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly -p tsconfig.build.json && pnpm run api-extractor:local",
    "clean": "rm -rf dist temp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "api-extractor": "api-extractor run && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-extractor:local": "api-extractor run --local && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-documenter": "api-documenter markdown -i temp -o docs && node ../../scripts/normalize-generated-markdown.mjs docs"
  },
  "dependencies": {
    "@formspec/analysis": "workspace:*",
    "@formspec/config": "workspace:*",
    "@formspec/core": "workspace:*",
    "pino": "^9.0.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "formspec",
    "language-server",
    "lsp",
    "typescript",
    "json-schema"
  ],
  "license": "MIT"
}
