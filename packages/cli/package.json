{
  "name": "@formspec/cli",
  "version": "0.1.0-alpha.61",
  "description": "CLI tool for generating JSON Schema and FormSpec from TypeScript classes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "formspec": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly -p tsconfig.build.json && pnpm run api-extractor:local",
    "clean": "rm -rf dist temp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "api-extractor": "api-extractor run && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-extractor:local": "api-extractor run --local && node ../../scripts/normalize-generated-markdown.mjs api-report"
  },
  "dependencies": {
    "typescript": "^5.9.3",
    "@formspec/build": "workspace:*",
    "@formspec/config": "workspace:*",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@formspec/core": "workspace:*",
    "@formspec/dsl": "workspace:*",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "formspec",
    "cli",
    "typescript",
    "json-schema",
    "code-generation"
  ]
}
