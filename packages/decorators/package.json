{
  "name": "@formspec/decorators",
  "version": "0.1.0-alpha.11",
  "description": "Marker-only TC39 Stage 3 decorators for FormSpec CLI static analysis",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/decorators.d.ts",
  "exports": {
    ".": {
      "types": "./dist/decorators.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly && api-extractor run --local",
    "clean": "rm -rf dist temp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:types": "tsd",
    "api-extractor": "api-extractor run",
    "api-extractor:local": "api-extractor run --local"
  },
  "devDependencies": {
    "tsd": "^0.31.0",
    "vitest": "^3.0.0"
  },
  "tsd": {
    "directory": "src/__tests__"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "formspec",
    "decorators",
    "typescript",
    "forms",
    "schema"
  ],
  "license": "UNLICENSED"
}
