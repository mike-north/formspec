{
  "name": "@formspec/eslint-plugin",
  "version": "0.1.0-alpha.59",
  "description": "ESLint rules for FormSpec decorator DSL type safety",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/eslint-plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/eslint-plugin.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "import": "./dist/base.js",
      "require": "./dist/base.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly && pnpm run api-extractor:local",
    "check:eslint-docs": "eslint-doc-generator --check --path-rule-list README.md --url-rule-doc \"https://github.com/mike-north/formspec/blob/main/packages/eslint-plugin/docs/rules/{name}.md\"",
    "clean": "rm -rf dist temp",
    "fix:eslint-docs": "eslint-doc-generator --path-rule-list README.md --url-rule-doc \"https://github.com/mike-north/formspec/blob/main/packages/eslint-plugin/docs/rules/{name}.md\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "api-extractor": "api-extractor run && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-extractor:local": "api-extractor run --local && node ../../scripts/normalize-generated-markdown.mjs api-report",
    "api-documenter": "api-documenter markdown -i temp -o docs && node ../../scripts/normalize-generated-markdown.mjs docs"
  },
  "dependencies": {
    "@formspec/analysis": "workspace:*",
    "@formspec/build": "workspace:*",
    "@formspec/config": "workspace:*",
    "@formspec/core": "workspace:*",
    "@typescript-eslint/utils": "^8.0.0"
  },
  "peerDependencies": {
    "eslint": "^9.39.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.55.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint-doc-generator": "^3.3.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "formspec",
    "decorators",
    "typescript"
  ]
}
