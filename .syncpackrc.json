{
  "$schema": "https://unpkg.com/syncpack@14/dist/schema.json",
  "source": [
    "package.json",
    "packages/*/package.json",
    "e2e/package.json"
  ],
  "semverGroups": [
    {
      "label": "Internal packages always use the pnpm workspace protocol",
      "dependencies": ["@formspec/*", "formspec"],
      "dependencyTypes": ["dev", "peer", "prod"],
      "packages": ["**"],
      "range": ""
    }
  ],
  "versionGroups": [
    {
      "label": "Internal packages always use the pnpm workspace protocol",
      "dependencies": ["@formspec/*", "formspec"],
      "dependencyTypes": ["dev", "peer", "prod"],
      "packages": ["**"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "TypeScript peer-deps advertise the supported range, and the e2e workspace runs compatibility tests against that same range — both wider than the workspace's pinned dev TS",
      "dependencies": ["typescript"],
      "dependencyTypes": ["peer"],
      "packages": ["**"],
      "pinVersion": ">=5.7.3 <7"
    },
    {
      "label": "The e2e workspace runs compatibility tests across the supported TypeScript range — its devDep tracks the peer-dep range, not the workspace pin",
      "dependencies": ["typescript"],
      "dependencyTypes": ["dev"],
      "packages": ["@formspec/e2e"],
      "pinVersion": ">=5.7.3 <7"
    }
  ],
  "sortAz": [
    "contributors",
    "dependencies",
    "devDependencies",
    "keywords",
    "overrides",
    "peerDependencies",
    "pnpm.overrides",
    "resolutions"
  ],
  "sortFirst": [
    "name",
    "description",
    "version",
    "author",
    "license",
    "private",
    "type",
    "main",
    "module",
    "types",
    "exports",
    "files",
    "scripts"
  ]
}
