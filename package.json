{
  "name": "formspec-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript monorepo workspace",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "lint": "eslint . && pnpm -r --filter './examples/*' run lint",
    "lint:fix": "eslint . --fix && pnpm -r --filter './examples/*' run lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm run build && pnpm --filter @formspec/e2e run test",
    "typecheck": "pnpm -r run typecheck",
    "api-extractor": "pnpm -r run api-extractor",
    "api-extractor:local": "pnpm -r run api-extractor:local",
    "api-documenter": "pnpm -r run api-documenter",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "syncpack": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@api-extractor-tools/declaration-file-normalizer": "^0.1.0-alpha.6",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.18.0",
    "@microsoft/api-documenter": "^7.26.10",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^22.13.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.1",
    "knip": "^6.6.1",
    "prettier": "^3.5.0",
    "syncpack": "^14.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "@types/eslint": "^9.6.1"
    }
  }
}
