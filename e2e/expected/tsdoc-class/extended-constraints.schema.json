{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "score": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 100
    },
    "quarterSteps": {
      "type": "number",
      "multipleOf": 0.25
    },
    "notes": {
      "type": "string",
      "description": "A detailed description of this field"
    }
  },
  "required": ["score", "quarterSteps"]
}
