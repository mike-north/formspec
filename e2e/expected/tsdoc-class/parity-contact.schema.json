{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "age": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "email": {
      "type": "string",
      "pattern": "^[^@]+@[^@]+$"
    },
    "country": {
      "enum": ["us", "ca", "uk"]
    },
    "bio": {
      "type": "string"
    }
  },
  "required": ["age", "name", "email", "country"]
}
