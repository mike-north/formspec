{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "cpuUsage": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "memoryUsage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "diskUsage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    }
  },
  "required": ["cpuUsage", "memoryUsage"]
}
