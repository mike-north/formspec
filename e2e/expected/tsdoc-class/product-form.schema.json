{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "currency": {
      "enum": [
        "usd",
        "eur",
        "gbp"
      ]
    },
    "active": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "$ref": "#/$defs/Record"
    }
  },
  "required": [
    "name",
    "price",
    "currency",
    "active"
  ],
  "$defs": {
    "Record": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    }
  }
}
