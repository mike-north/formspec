{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "confidence": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 5,
      "maximum": 100
    },
    "score": {
      "type": "number",
      "multipleOf": 5,
      "minimum": 0,
      "maximum": 100
    },
    "ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  },
  "required": ["confidence", "score", "ratio"]
}
