{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "title": "Full Name"
    },
    "preciseScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "multipleOf": 0.5,
      "title": "Precise Score"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "title": "Tag"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1,
      "maxItems": 5,
      "title": "Tags"
    }
  },
  "required": ["name", "preciseScore", "tags"]
}
