{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "Billing",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/customerName",
          "label": "Name"
        },
        {
          "type": "Group",
          "label": "Billing Address",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/billingAddress/properties/street",
              "label": "Street"
            },
            {
              "type": "Control",
              "scope": "#/properties/billingAddress/properties/city",
              "label": "City"
            },
            {
              "type": "Control",
              "scope": "#/properties/billingAddress/properties/zip",
              "label": "ZIP"
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "label": "Shipping Address",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/shippingAddress/properties/street",
          "label": "Street"
        },
        {
          "type": "Control",
          "scope": "#/properties/shippingAddress/properties/city",
          "label": "City"
        },
        {
          "type": "Control",
          "scope": "#/properties/shippingAddress/properties/zip",
          "label": "ZIP"
        }
      ]
    },
    {
      "type": "Control",
      "scope": "#/properties/lineItems",
      "label": "Line Items"
    }
  ]
}
