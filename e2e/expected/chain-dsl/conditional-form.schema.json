{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "paymentMethod": {
      "title": "Payment Method",
      "enum": ["card", "bank_transfer", "crypto"]
    },
    "cardNumber": {
      "title": "Card Number",
      "type": "string"
    },
    "expiryDate": {
      "title": "Expiry",
      "type": "string"
    },
    "accountNumber": {
      "title": "Account Number",
      "type": "string"
    },
    "routingNumber": {
      "title": "Routing Number",
      "type": "string"
    },
    "savePaymentMethod": {
      "title": "Save for later",
      "type": "boolean"
    }
  },
  "required": ["paymentMethod"]
}
