{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "Personal Info",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/firstName",
          "label": "First Name"
        },
        {
          "type": "Control",
          "scope": "#/properties/lastName",
          "label": "Last Name"
        },
        {
          "type": "Control",
          "scope": "#/properties/email",
          "label": "Email"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Preferences",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/contactMethod",
          "label": "Preferred Contact Method"
        },
        {
          "type": "Control",
          "scope": "#/properties/phoneNumber",
          "label": "Phone Number",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/contactMethod",
              "schema": {
                "const": "phone"
              }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/age",
          "label": "Age"
        },
        {
          "type": "Control",
          "scope": "#/properties/newsletter",
          "label": "Subscribe to Newsletter"
        }
      ]
    }
  ]
}
