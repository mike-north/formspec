{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "firstName": {
      "title": "First Name",
      "type": "string"
    },
    "lastName": {
      "title": "Last Name",
      "type": "string"
    },
    "email": {
      "title": "Email",
      "type": "string"
    },
    "contactMethod": {
      "title": "Preferred Contact Method",
      "enum": ["email", "phone", "mail"]
    },
    "phoneNumber": {
      "title": "Phone Number",
      "type": "string"
    },
    "age": {
      "title": "Age",
      "type": "number",
      "minimum": 0,
      "maximum": 150
    },
    "newsletter": {
      "title": "Subscribe to Newsletter",
      "type": "boolean"
    }
  },
  "required": ["firstName", "lastName", "contactMethod"]
}
