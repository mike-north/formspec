{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "port": {
      "type": "number",
      "minimum": 1,
      "maximum": 65535
    },
    "hostname": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253
    },
    "logLevel": {
      "type": "string",
      "pattern": "^(debug|info|warn|error)$"
    },
    "timeoutMs": {
      "type": "number",
      "minimum": 1000,
      "maximum": 30000
    },
    "allowedOrigins": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "required": ["port", "hostname", "logLevel", "allowedOrigins"]
}
