{
  "type": "object",
  "properties": {
    "cpuThreshold": {
      "type": "number"
    },
    "memoryThreshold": {
      "type": "number"
    },
    "adminEmail": {
      "type": "string"
    },
    "enableAlerts": {
      "type": "boolean"
    },
    "alertChannels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["email", "slack", "pagerduty"]
      }
    },
    "retryPolicy": {
      "type": "object",
      "properties": {
        "maxRetries": {
          "type": "number"
        },
        "backoffMs": {
          "type": "number"
        }
      },
      "required": ["maxRetries", "backoffMs"]
    }
  },
  "required": ["cpuThreshold", "memoryThreshold", "adminEmail", "enableAlerts", "alertChannels"]
}
